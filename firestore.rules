rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // === Helper functions ===
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUser(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function getUserAfter(uid) {
      return getAfter(/databases/$(database)/documents/users/$(uid)).data;
    }

    function hasUid(values, uid) {
      return values is list && uid in values;
    }

    function onlySocialUserFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['friends', 'requestsSent', 'requestsReceived', 'updatedAt']);
    }

    function signedUserIsInvolvedInSocialWrite(userId) {
      return request.auth.uid == userId
        || hasUid(resource.data.friends, request.auth.uid)
        || hasUid(resource.data.requestsSent, request.auth.uid)
        || hasUid(resource.data.requestsReceived, request.auth.uid)
        || hasUid(request.resource.data.friends, request.auth.uid)
        || hasUid(request.resource.data.requestsSent, request.auth.uid)
        || hasUid(request.resource.data.requestsReceived, request.auth.uid);
    }

    function areFriends(uid1, uid2) {
      return hasUid(getUser(uid1).friends, uid2) && hasUid(getUser(uid2).friends, uid1);
    }

    function areFriendsAfter(uid1, uid2) {
      return hasUid(getUserAfter(uid1).friends, uid2) && hasUid(getUserAfter(uid2).friends, uid1);
    }

    function isDmChatData(data) {
      return data.type == 'dm'
        && data.participants is list
        && data.participants.size() == 2
        && data.members is list
        && data.members.size() == 2;
    }

    function isChatParticipant(data) {
      return (data.members is list && request.auth.uid in data.members)
        || (data.participants is list && request.auth.uid in data.participants)
        || data.memberMap[request.auth.uid] == true;
    }

    function isDeterministicDm(chatId, data) {
      return isDmChatData(data)
        && chatId == data.participants[0] + '_' + data.participants[1];
    }

    function canUseDmChat(chatId, data) {
      return isSignedIn()
        && isChatParticipant(data)
        && isDeterministicDm(chatId, data)
        && areFriends(data.participants[0], data.participants[1]);
    }

    function canCreateDmChat(chatId) {
      return isSignedIn()
        && isChatParticipant(request.resource.data)
        && isDeterministicDm(chatId, request.resource.data)
        && areFriendsAfter(request.resource.data.participants[0], request.resource.data.participants[1]);
    }

    function isOwner() {
      return isSignedIn() && (getUserData().role == 'owner' || request.auth.token.email == 'iamwe@nexify.com');
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    function isStaff() {
      return isOwner() || isAdmin();
    }

    // === Users collection ===
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.auth.uid == userId || userId == 'nexify_ai');
      
      // Strict update rules: users can only edit non-sensitive fields
      allow update: if (isSignedIn() && request.auth.uid == userId 
                        && (
                          // If current document has no role, user can initialize it with starter defaults
                          (
                            !resource.data.keys().hasAny(['role']) 
                            && request.resource.data.role == 'member'
                            && request.resource.data.rank == 'rookie'
                            && request.resource.data.xp == 0
                            && request.resource.data.level == 1
                            && request.resource.data.verified == false
                          )
                          || !request.resource.data.diff(resource.data).affectedKeys()
                             .hasAny(['role', 'rank', 'xp', 'level', 'verified', 'badges', 'banned'])
                        )
                       )
                    || (isSignedIn()
                        && onlySocialUserFieldsChanged()
                        && signedUserIsInvolvedInSocialWrite(userId)
                       )
                    || (isStaff() 
                        // Staff can update mostly anything, but only owner can assign owner/admin
                        && (request.resource.data.role != 'owner' || isOwner())
                        && (resource.data.role != 'owner' || isOwner())
                       );
    }
    
    // === Roles & Ranks ===
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    
    match /ranks/{rankId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    
    // === Leaderboards ===
    match /leaderboards/{lbId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
      
      match /users/{userId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (request.auth.uid == userId || isStaff());
      }
    }
    
    // === Admin Logs & XP Events ===
    match /adminLogs/{logId} {
      allow read: if isStaff();
      allow create: if isStaff();
    }

    match /xpEvents/{eventId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    // === Rooms & Chats ===
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isStaff());
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isStaff() || (isSignedIn() && resource.data.senderId == request.auth.uid);
      }
    }
    
    match /chats/{chatId} {
      allow read: if isSignedIn() && isChatParticipant(resource.data);
      allow update: if canUseDmChat(chatId, resource.data);
      allow create: if canCreateDmChat(chatId);
      
      match /messages/{messageId} {
        allow read: if canUseDmChat(chatId, get(/databases/$(database)/documents/chats/$(chatId)).data);
        allow create: if request.resource.data.senderId == request.auth.uid
          && canUseDmChat(chatId, get(/databases/$(database)/documents/chats/$(chatId)).data);
        allow update: if canUseDmChat(chatId, get(/databases/$(database)/documents/chats/$(chatId)).data);
        allow delete: if isStaff() || (isSignedIn()
          && resource.data.senderId == request.auth.uid
          && canUseDmChat(chatId, get(/databases/$(database)/documents/chats/$(chatId)).data));
      }
    }

    // === Friends & Requests ===
    match /friends/{friendId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userMap[request.auth.uid] == true || isStaff());
      allow create: if isSignedIn() && request.resource.data.userMap[request.auth.uid] == true;
      allow update, delete: if isSignedIn() && (resource.data.userMap[request.auth.uid] == true || isStaff());
    }

    match /friendRequests/{requestId} {
      allow read: if isSignedIn() && (resource == null || request.auth.uid == resource.data.to || request.auth.uid == resource.data.from || isStaff());
      allow create: if isSignedIn() && request.resource.data.from == request.auth.uid;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.to || request.auth.uid == resource.data.from || isStaff());
    }

    // === Calls ===
    match /calls/{callId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isStaff();
      match /iceCandidates/{id} {
        allow read, create: if isSignedIn();
      }
    }

    // === Music ===
    match /musicRooms/{roomId} {
      allow read, create, update: if isSignedIn();
    }
    match /userMusicStatus/{uid} {
      allow read, create, update: if isSignedIn();
    }
    match /musicActivity/{id} {
      allow read, create: if isSignedIn();
    }

    // === Activity, Focus, Tasks ===
    match /activityFeed/{activityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
    match /focusStats/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }
    match /users/{userId}/data/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    match /users/{userId}/tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    match /focusPods/{podId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isStaff());
    }
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource == null || resource.data.toUid == request.auth.uid || isStaff());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.toUid == request.auth.uid || isStaff());
      allow delete: if isSignedIn() && (resource.data.toUid == request.auth.uid || isStaff());
    }
    match /milestones/{milestoneId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isStaff();
    }

    // === Catch-all ===
    match /{path=**} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
  }
}
